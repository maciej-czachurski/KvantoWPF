<UserControl x:Class="KvantoWPF.Controls.CircularProgressBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid Width="170" Height="170">
        <Ellipse Stroke="#E5E7EB" StrokeThickness="12" />
        <Path Data="{Binding ProgressGeometry, ElementName=Root}"
              Stroke="{Binding AccentBrush, ElementName=Root}"
              StrokeThickness="12"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round" />
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="{Binding CenterText, ElementName=Root}"
                       HorizontalAlignment="Center"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#111827" />
            <TextBlock Text="{Binding Caption, ElementName=Root}"
                       HorizontalAlignment="Center"
                       FontSize="13"
                       Foreground="#6B7280" />
        </StackPanel>
    </Grid>
</UserControl>
