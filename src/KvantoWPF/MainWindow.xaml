<Window x:Class="KvantoWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:KvantoWPF.Controls"
        Title="Kvanto"
        Width="1400"
        Height="920"
        MinWidth="1200"
        MinHeight="800"
        Background="#F3F4F6">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="20">
        <StatusBar DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusBarText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="Ctrl+Alt+S Start/Pause · Ctrl+Alt+N Skip · Ctrl+Alt+K Show window" />
            </StatusBarItem>
        </StatusBar>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Kvanto" FontSize="34" FontWeight="Bold" Foreground="#111827" />
                        <TextBlock Text="Modern daily task tracker with Pomodoro, calendar, reports, tray control, and compact overlay." FontSize="15" Foreground="#4B5563" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Open compact overlay" Command="{Binding OpenCompactViewCommand}" Margin="0,0,10,0" Padding="18,10" />
                        <Button Content="{Binding PinText}" Command="{Binding TogglePinCommand}" Padding="18,10" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,20,16">
                        <StackPanel>
                            <TextBlock Text="Pomodoro Timer" FontSize="22" FontWeight="Bold" Foreground="#111827" />
                            <TextBlock Text="{Binding SelectedTask.Title, TargetNullValue=Select a task to begin}" Margin="0,6,0,14" FontSize="15" Foreground="#6B7280" />
                            <controls:CircularProgressBar Value="{Binding ProgressValue}"
                                                          AccentBrush="{Binding SessionBrush}"
                                                          CenterText="{Binding TimeRemainingText}"
                                                          Caption="{Binding SessionLabel}" />
                            <UniformGrid Columns="3" Margin="0,18,0,0">
                                <Button Content="{Binding StartPauseText}" Command="{Binding StartPauseCommand}" Margin="6" Padding="10" />
                                <Button Content="Stop" Command="{Binding StopCommand}" Margin="6" Padding="10" />
                                <Button Content="Skip" Command="{Binding SkipCommand}" Margin="6" Padding="10" />
                            </UniformGrid>
                            <TextBlock Text="{Binding SelectedTaskStats}" Margin="0,16,0,0" TextWrapping="Wrap" Foreground="#4B5563" />
                            <TextBlock Text="Tray icon turns red in focus mode and green on breaks." Margin="0,8,0,0" Foreground="#6B7280" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Work" FontWeight="Bold" Foreground="#374151" />
                                    <TextBox Text="{Binding WorkMinutes}" Margin="0,8,10,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Short break" FontWeight="Bold" Foreground="#374151" />
                                    <TextBox Text="{Binding ShortBreakMinutes}" Margin="0,8,10,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Long break" FontWeight="Bold" Foreground="#374151" />
                                    <TextBox Text="{Binding LongBreakMinutes}" Margin="0,8,10,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="Long break every" FontWeight="Bold" Foreground="#374151" />
                                    <TextBox Text="{Binding LongBreakFrequency}" Margin="0,8,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TabControl Background="Transparent" BorderThickness="0">
                            <TabItem Header="Tasks">
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="340" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,20,0">
                                        <StackPanel>
                                            <TextBlock Text="Task Details" FontSize="20" FontWeight="Bold" />
                                            <TextBlock Text="Title" Margin="0,14,0,4" />
                                            <TextBox Text="{Binding TaskTitle, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Description" Margin="0,14,0,4" />
                                            <TextBox Text="{Binding TaskDescription, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="90" TextWrapping="Wrap" />
                                            <TextBlock Text="Category" Margin="0,14,0,4" />
                                            <TextBox Text="{Binding TaskCategory, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Priority" Margin="0,14,0,4" />
                                            <ComboBox ItemsSource="{Binding PriorityOptions}" SelectedItem="{Binding TaskPriority}" />
                                            <TextBlock Text="Estimated Pomodoros" Margin="0,14,0,4" />
                                            <TextBox Text="{Binding EstimatedPomodoros}" />
                                            <UniformGrid Columns="2" Margin="0,18,0,0">
                                                <Button Content="New" Command="{Binding NewTaskCommand}" Margin="6" Padding="10" />
                                                <Button Content="Save" Command="{Binding SaveTaskCommand}" Margin="6" Padding="10" />
                                            </UniformGrid>
                                            <UniformGrid Columns="2" Margin="0,8,0,0">
                                                <Button Content="Archive / Restore" Command="{Binding ToggleTaskStateCommand}" Margin="6" Padding="10" />
                                                <Button Content="Delete" Command="{Binding DeleteTaskCommand}" Margin="6" Padding="10" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,0">
                                        <TabControl>
                                            <TabItem Header="Active tasks">
                                                <ListView ItemsSource="{Binding ActiveTasks}" SelectedItem="{Binding SelectedTask}" Margin="0,10,0,0">
                                                    <ListView.View>
                                                        <GridView>
                                                            <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}" Width="180" />
                                                            <GridViewColumn Header="Category" DisplayMemberBinding="{Binding Category}" Width="120" />
                                                            <GridViewColumn Header="Priority" DisplayMemberBinding="{Binding Priority}" Width="90" />
                                                            <GridViewColumn Header="Tracked" DisplayMemberBinding="{Binding WorkedTimeDisplay}" Width="90" />
                                                            <GridViewColumn Header="Days" DisplayMemberBinding="{Binding DaysWorkedCount}" Width="70" />
                                                            <GridViewColumn Header="Pomodoros" DisplayMemberBinding="{Binding PomodoroProgress}" Width="110" />
                                                        </GridView>
                                                    </ListView.View>
                                                </ListView>
                                            </TabItem>
                                            <TabItem Header="Archived tasks">
                                                <ListView ItemsSource="{Binding ArchivedTasks}" SelectedItem="{Binding SelectedTask}" Margin="0,10,0,0">
                                                    <ListView.View>
                                                        <GridView>
                                                            <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}" Width="180" />
                                                            <GridViewColumn Header="Category" DisplayMemberBinding="{Binding Category}" Width="120" />
                                                            <GridViewColumn Header="Priority" DisplayMemberBinding="{Binding Priority}" Width="90" />
                                                            <GridViewColumn Header="Tracked" DisplayMemberBinding="{Binding WorkedTimeDisplay}" Width="90" />
                                                            <GridViewColumn Header="Days" DisplayMemberBinding="{Binding DaysWorkedCount}" Width="70" />
                                                            <GridViewColumn Header="Pomodoros" DisplayMemberBinding="{Binding PomodoroProgress}" Width="110" />
                                                        </GridView>
                                                    </ListView.View>
                                                </ListView>
                                            </TabItem>
                                        </TabControl>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Calendar">
                                <StackPanel Margin="0,10,0,0">
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                <Button Content="◀" Command="{Binding PreviousMonthCommand}" Width="44" Margin="0,0,8,0" />
                                                <Button Content="▶" Command="{Binding NextMonthCommand}" Width="44" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding DisplayMonthLabel}" FontSize="22" FontWeight="Bold" />
                                        </DockPanel>
                                    </Border>

                                    <UniformGrid Columns="7" Margin="0,0,0,8">
                                        <TextBlock Text="Mon" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="Tue" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="Wed" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="Thu" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="Fri" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="Sat" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="Sun" FontWeight="Bold" HorizontalAlignment="Center" />
                                    </UniformGrid>

                                    <ItemsControl ItemsSource="{Binding CalendarDays}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="7" Rows="6" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding BackgroundHex}"
                                                        BorderBrush="#D1D5DB"
                                                        BorderThickness="1"
                                                        Padding="8"
                                                        Margin="2"
                                                        MinHeight="110">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DayLabel}" FontWeight="Bold" Foreground="#111827" />
                                                        <ItemsControl ItemsSource="{Binding Entries}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="{Binding ColorHex}" CornerRadius="8" Margin="0,6,0,0" Padding="6,4">
                                                                        <TextBlock Text="{Binding Display}" Foreground="White" FontSize="11" TextWrapping="Wrap" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </TabItem>

                            <TabItem Header="Reports">
                                <StackPanel Margin="0,10,0,0">
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <WrapPanel VerticalAlignment="Center">
                                            <StackPanel Margin="0,0,16,0">
                                                <TextBlock Text="Range" />
                                                <ComboBox Width="160" ItemsSource="{Binding ReportRangeOptions}" SelectedItem="{Binding SelectedReportRange}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,0" Visibility="{Binding IsCustomRange, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Start" />
                                                <DatePicker SelectedDate="{Binding ReportStartDate}" Width="150" />
                                            </StackPanel>
                                            <StackPanel Visibility="{Binding IsCustomRange, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="End" />
                                                <DatePicker SelectedDate="{Binding ReportEndDate}" Width="150" />
                                            </StackPanel>
                                        </WrapPanel>
                                    </Border>

                                    <UniformGrid Columns="5" Margin="0,0,0,16">
                                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                                            <StackPanel>
                                                <TextBlock Text="Total Time" Foreground="#6B7280" />
                                                <TextBlock Text="{Binding ReportTotalMinutes, StringFormat={}{0} min}" FontSize="24" FontWeight="Bold" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                                            <StackPanel>
                                                <TextBlock Text="Sessions" Foreground="#6B7280" />
                                                <TextBlock Text="{Binding ReportSessionCount}" FontSize="24" FontWeight="Bold" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                                            <StackPanel>
                                                <TextBlock Text="Active Days" Foreground="#6B7280" />
                                                <TextBlock Text="{Binding ReportActiveDays}" FontSize="24" FontWeight="Bold" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                                            <StackPanel>
                                                <TextBlock Text="Daily Average" Foreground="#6B7280" />
                                                <TextBlock Text="{Binding ReportDailyAverage}" FontSize="24" FontWeight="Bold" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                                            <StackPanel>
                                                <TextBlock Text="Current Streak" Foreground="#6B7280" />
                                                <TextBlock Text="{Binding ReportCurrentStreak, StringFormat={}{0} days}" FontSize="24" FontWeight="Bold" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,20,0">
                                            <StackPanel>
                                                <TextBlock Text="Per-task distribution" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />
                                                <ItemsControl ItemsSource="{Binding TaskReportItems}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Margin="0,0,0,12">
                                                                <DockPanel>
                                                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" DockPanel.Dock="Left" />
                                                                    <TextBlock Text="{Binding ValueLabel}" DockPanel.Dock="Right" />
                                                                </DockPanel>
                                                                <Border Background="#E5E7EB" Height="18" CornerRadius="9" Margin="0,6,0,0">
                                                                    <Border Background="{Binding ColorHex}" Width="{Binding BarWidth}" Height="18" CornerRadius="9" HorizontalAlignment="Left" />
                                                                </Border>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="0">
                                            <StackPanel>
                                                <TextBlock Text="Daily activity" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />
                                                <ItemsControl ItemsSource="{Binding DailyReportItems}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Margin="0,0,0,12">
                                                                <DockPanel>
                                                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" DockPanel.Dock="Left" />
                                                                    <TextBlock Text="{Binding ValueLabel}" DockPanel.Dock="Right" />
                                                                </DockPanel>
                                                                <Border Background="#DBEAFE" Height="18" CornerRadius="9" Margin="0,6,0,0">
                                                                    <Border Background="{Binding ColorHex}" Width="{Binding BarWidth}" Height="18" CornerRadius="9" HorizontalAlignment="Left" />
                                                                </Border>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </TabItem>

                            <TabItem Header="Settings &amp; Shortcuts">
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Windows 11 workflow helpers" FontSize="20" FontWeight="Bold" />
                                        <TextBlock Text="• Ctrl+Alt+S starts or pauses the current Pomodoro." Margin="0,16,0,0" />
                                        <TextBlock Text="• Ctrl+Alt+N skips to the next session." Margin="0,8,0,0" />
                                        <TextBlock Text="• Ctrl+Alt+K restores the Kvanto window from anywhere." Margin="0,8,0,0" />
                                        <TextBlock Text="• Closing the main window hides it to the system tray instead of exiting." Margin="0,8,0,0" />
                                        <TextBlock Text="• The tray menu exposes open, start/pause, stop, skip, compact overlay, and exit." Margin="0,8,0,0" />
                                        <TextBlock Text="• Session-complete notifications prompt for the next action." Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </TabItem>
                        </TabControl>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
