<Window x:Class="KvantoWPF.CompactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:KvantoWPF.Controls"
        Title="Kvanto Overlay"
        Height="310"
        Width="260"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Topmost="True"
        Background="#F9FAFB">
    <Border Background="White" Margin="12" Padding="14" CornerRadius="16">
        <StackPanel>
            <TextBlock Text="Compact Overlay" FontSize="16" FontWeight="Bold" Foreground="#111827" />
            <TextBlock Text="{Binding SelectedTask.Title, TargetNullValue=No active task}" Margin="0,4,0,10" Foreground="#6B7280" />
            <controls:CircularProgressBar Value="{Binding ProgressValue}"
                                          AccentBrush="{Binding SessionBrush}"
                                          CenterText="{Binding TimeRemainingText}"
                                          Caption="{Binding SessionLabel}" />
            <UniformGrid Columns="3" Margin="0,16,0,0">
                <Button Content="{Binding StartPauseText}" Command="{Binding StartPauseCommand}" Margin="4" />
                <Button Content="Skip" Command="{Binding SkipCommand}" Margin="4" />
                <Button Content="{Binding PinText}" Command="{Binding TogglePinCommand}" Margin="4" />
            </UniformGrid>
        </StackPanel>
    </Border>
</Window>
